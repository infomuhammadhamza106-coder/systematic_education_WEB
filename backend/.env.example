# Copy this file to .env and fill in your values

PORT=5000
FRONTEND_URL=http://localhost:5173
ADMIN_PASSWORD=your_admin_password_here

# Supabase — JS Client (HTTPS)
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Email Notifications (SMTP)
# Get SMTP details from your email/hosting provider (cPanel, Hostinger, etc.)
SMTP_HOST=mail.systematics.com.pk
SMTP_PORT=587
SMTP_USER=info@systematics.com.pk
SMTP_PASS=your_email_password_here

# Owner notification email (receives new order alerts)
OWNER_EMAIL=madiha@systematics.com.pk
